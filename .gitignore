# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environment
venv/
.venv/

# Output (except latest.png and theme_*.png which are tracked)
output/*.png
!output/latest.png
!output/theme_*.png
output/*.json
output/*.txt

# Runtime state (cache, breaker, quota, sync tokens, theme state)
state/

# Config and credentials (user-specific, sensitive)
config/config.yaml
credentials/

# Misc
*.egg-info/
dist/
build/
.DS_Store
.coverage
htmlcov/
