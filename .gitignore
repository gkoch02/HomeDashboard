# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environment
venv/
.venv/

# Output (runtime artifacts; only latest.png is tracked).  Per-theme
# preview PNGs are now committed under assets/previews/ — see
# docs/previews.md.
output/*.png
!output/latest.png
output/*.json
output/*.txt

# Runtime state (cache, breaker, quota, sync tokens, theme state)
state/

# Config and credentials (user-specific, sensitive)
config/config.yaml
config/web.yaml
config/birthdays.json
credentials/

# Misc
*.egg-info/
dist/
build/
.DS_Store
.coverage
htmlcov/
